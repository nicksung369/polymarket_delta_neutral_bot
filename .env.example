# Polymarket wallet private key (Polygon network)
PRIVATE_KEY=0xyour_private_key_here

# Polygon RPC endpoint (optional, defaults to https://polygon-rpc.com)
POLYGON_RPC=https://polygon-rpc.com

# Target market condition IDs (JSON array)
# Find via: https://gamma-api.polymarket.com/events?slug=<event-slug>
# Leave empty [] for auto-discovery of high-reward markets
TARGET_MARKETS=[]
